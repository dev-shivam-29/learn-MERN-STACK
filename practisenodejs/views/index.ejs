<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Todo App</title>

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
  <div class="main w-full min-h-screen bg-zinc-900 text-white p-10">
    <!-- Form -->
    <div class="form mb-8">
      <form class="flex gap-3">
        <input
          type="text"
          placeholder="Enter task"
          class="px-4 py-2 rounded-md bg-zinc-800 outline-none w-80"
        />

        <button class="px-4 py-2 bg-blue-600 rounded-md">
          Add Task
        </button>
      </form>
    </div>

    <!-- Tasks -->
    <div class="tasks flex gap-4 flex-wrap">

      <div class="task w-72 px-4 py-3 rounded-md bg-zinc-800">
        <h3 class="text-xl font-semibold">Complete Node.js</h3>
        <p class="text-zinc-400 mt-2">
          Finish Express and EJS practice.
        </p>
      </div>

      <div class="task w-72 px-4 py-3 rounded-md bg-zinc-800">
        <h3 class="text-xl font-semibold">Learn Tailwind</h3>
        <p class="text-zinc-400 mt-2">
          Practice flexbox and grid.
        </p>
      </div>

    </div>

    <!-- No Task -->
    <h3 class="text-zinc-500 mt-8">
      No task yet
    </h3>

  </div>
</body>
</html>